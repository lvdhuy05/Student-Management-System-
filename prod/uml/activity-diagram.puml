@startuml
title SMS - Activity Diagram (3 Roles)

start

:Dang nhap he thong;
if (Xac thuc + RBAC hop le?) then (Co)
  :Chuyen den Trang chu theo role;
else (Khong)
  :Thong bao loi dang nhap / khong duoc cap quyen;
  stop
endif

if (Role = ADMIN?) then (Co)
  repeat
    :Quan tri Sinh vien / Hoc phan / Lop hoc phan;
    :Tao dang ky hoc phan;
    :Nhap hoac sua diem;
    :Theo doi bao cao + audit log;
  repeat while (Tiep tuc?) is (Co)
  stop
endif

if (Role = SINH_VIEN?) then (Co)
  :Mo trang Mon da dang ky;
  :Chon lop hoc phan can dang ky;
  if (Lop con cho + chua trung hoc phan/hoc ky?) then (Dat)
    :Luu dang ky hoc phan;
  else (Khong dat)
    :Bao loi nghiep vu;
  endif
  :Xem bang diem ca nhan;
  stop
endif

if (Role = GIANG_VIEN?) then (Co)
  :Mo trang Lop cua toi;
  :Chon lop hoc phan;
  :Xem danh sach sinh vien trong lop;
  :Chon ngay hoc va diem danh;
  :Nhap/Sua diem cho tung sinh vien;
  :He thong tu dong tinh GPA va cap nhat hoc luc;
  stop
endif

stop
@enduml
